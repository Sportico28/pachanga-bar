rules_version = '2';

// Firebase Storage rules voor Bar28
// Foto's voor artikels en keywords.
// Alleen Bram (admin) mag uploaden. Iedereen die ingelogd is mag lezen.

service firebase.storage {
  match /b/{bucket}/o {

    // Artikel- en keyword-foto's
    match /{folder}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'bram.denyn@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024   // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
